# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL="https://tytxjcrcnjvszljbmyos.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: The service role key for Supabase (keep this secret).
# Use the 'service_role' key from Supabase dashboard -> Settings -> API
SUPABASE_SERVICE_ROLE_KEY=""

# JWT_SECRET: Secret for JWT signing.
JWT_SECRET="ifonelab-secret-key-2024"
